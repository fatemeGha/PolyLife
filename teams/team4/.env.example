# Team team4 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9104).
TEAM_PORT=9104
CORE_BASE_URL=http://core:8000
POSTGRES_DB=team4
POSTGRES_USER=team4_user
POSTGRES_PASSWORD=team4pass
DATABASE_URL=postgres://team4_user:team4pass@db:5432/team4
DJANGO_SECRET_KEY=dev-only-team4-secret-change-me
