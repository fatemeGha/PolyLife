# PolyLife Team 8 — development environment.
# Copy to `.env` (the run scripts do this automatically). Never commit `.env`.
# `.env` is git-ignored and must never be committed.

TEAM_PORT=9108
DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,gateway

# Core authentication service used by the Nginx forward-auth template.
URL_BASE_CORE=http://core:8000

POSTGRES_DB=team8
POSTGRES_USER=team8_user
POSTGRES_PASSWORD=team8pass
URL_DATABASE=postgres://team8_user:team8pass@db:5432/team8

DJANGO_SECRET_KEY=dev-only-team8-secret-key-change-before-production-40031701
GATEWAY_SHARED_SECRET=dev-only-team8-gateway-secret-change-before-production

# Redis-backed feed cache and rate-limit storage.
CACHE_URL=redis://redis:6379/0

# S3-compatible object storage (MinIO in development, replaceable by AWS S3).
USE_S3=True
MINIO_ROOT_USER=team8_minio
MINIO_ROOT_PASSWORD=team8_minio_secret_change_me
AWS_STORAGE_BUCKET_NAME=team8-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9108/media/team8-media
AWS_S3_URL_PROTOCOL=http:

LOG_LEVEL=INFO

# Set these only when TLS is terminated by a trusted reverse proxy.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
