# Team team7 — environment.  Copy to `.env` (the run script does this for you).
# `.env` is git-ignored and must never be committed.

# Your team's unique port (open http://localhost:9107).
TEAM_PORT=9107

# The core that authenticates your users.
CORE_BASE_URL=http://core:8000

ALLOWED_HOSTS=localhost,127.0.0.1

# Your team's own database (used once you enable the db + backend services).
DATABASE_URL=mongodb://team7_user:team7_pass@db:27017/team7_db?authSource=admin
MONGO_INITDB_ROOT_USERNAME=team7_user
MONGO_INITDB_ROOT_PASSWORD=team7_pass
DEBUG=True

# Your backend's secret key (change for production).
DJANGO_SECRET_KEY=dev-only-team7-secret-change-me

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

REDIS_URL=redis://redis:6379/0
