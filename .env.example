# Copy this file to `.env` and adjust values for your local setup.
# `.env` is git-ignored and must never be committed.

# Django
DJANGO_SECRET_KEY=dev-only-insecure-secret-key-change-me-in-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: local SQLite file)
# For Postgres/MySQL use a URL, e.g.:
# DATABASE_URL=postgres://user:pass@localhost:5432/polylife
# DATABASE_URL=sqlite:///db.sqlite3

# Team microservices. Comma-separated app labels; empty until teams exist.
# Each listed team also needs its own database (unique credentials), provided
# via <TEAM>_DATABASE_URL. Without it, a per-team SQLite file is used locally.
# TEAM_APPS=team1,team2
# TEAM1_DATABASE_URL=postgres://team1_user:team1_pass@db-team1:5432/team1
# TEAM2_DATABASE_URL=postgres://team2_user:team2_pass@db-team2:5432/team2

# JWT (defaults to DJANGO_SECRET_KEY if unset; TTLs are in seconds)
# JWT_SECRET=change-me
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=604800

# Auth cookies (set JWT_COOKIE_SECURE=True in production / HTTPS)
# JWT_COOKIE_SECURE=False
# JWT_COOKIE_SAMESITE=Lax
